{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Packet",
  "description": "Canonical packet shape shared between backend/app/models/packet.py and frontend/src/types/packet.ts. Kept as a JSON Schema for now for reference; a future version may generate both from this file directly.",
  "type": "object",
  "required": ["id", "timestamp", "src_ip", "dst_ip", "protocol", "length", "status", "summary"],
  "properties": {
    "id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "src_ip": { "type": "string" },
    "dst_ip": { "type": "string" },
    "protocol": { "type": "string", "enum": ["TCP", "UDP", "ICMP", "ARP", "DNS", "HTTP", "HTTPS", "OTHER"] },
    "src_port": { "type": ["integer", "null"] },
    "dst_port": { "type": ["integer", "null"] },
    "length": { "type": "integer" },
    "status": { "type": "string", "enum": ["ok", "warning", "danger"] },
    "summary": { "type": "string" },
    "headers": { "type": "object" },
    "payload_hex": { "type": "string" },
    "payload_ascii": { "type": "string" }
  }
}
